{
	"private": true,
	"name": "cowork",
	"type": "module",
	"repository": "git@github.com:elmanu-rc/cowork.git",
	"version": "0.0.0",
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"lint": "bun run lint:biome && bun run lint:markdown",
		"lint:biome": "biome check . --write",
		"lint:markdown": "bunx markdownlint-cli2 'projects/**/*.md' --fix",
		"husky": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.7",
		"@semantic-release/commit-analyzer": "13.0.1",
		"@semantic-release/github": "12.0.6",
		"@semantic-release/release-notes-generator": "14.1.0",
		"@types/node": "25.5.2",
		"cz-conventional-changelog": "3.3.0",
		"husky": "9.1.7",
		"typescript": "6.0.2",
		"@types/bun": "1.3.11",
		"bun-types": "1.3.11",
		"markdownlint-cli2-formatter-pretty": "0.0.10",
		"markdownlint-cli2": "0.22.0"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	}
}
